{
  "name": "Typst PyExec",
  "image": "ghcr.io/arkanthara/typst_pyexec:latest",
  "features": {},
  "forwardPorts": [23625],
  "portsAttributes": {
    "23625": {
      "label": "Tinymist Preview",
      "onAutoForward": "openBrowser"
    }
  },
  "containerEnv": {
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "PIP_NO_CACHE_DIR": "1"
  },
  "postCreateCommand": "bash -lc 'python -m pip install --no-cache-dir numpy matplotlib'",
  "customizations": {
    "vscode": {
      "extensions": [
        "myriad-dreamin.tinymist",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
